@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OnlineCourses</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OnlineCourses.Web.styles.css" asp-append-version="true" />
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3 custom-navbar">
            <div class="container-fluid px-4">

                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <span class="logo-icon">📖</span>
                    <span>OnlineCourses</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav align-items-center gap-2">
                        <li class="nav-item">
                            <form method="get" action="/Courses/Search" class="search-form">
                                <input type="text" name="query" class="search-input" placeholder="Пошук курсу..." />
                                <button type="submit" class="search-btn">🔍</button>
                            </form>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Головна</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Courses" asp-action="Index">Курси</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Courses" asp-action="Cabinet">Мої курси</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Privacy">Про нас</a>
                        </li>
                        @if (Context.Session.GetString("UserRole") == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Admin">Адмін-панель</a>
                            </li>
                        }

                        @if (Context.Session.GetString("UserRole") == "Teacher")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Teacher">Кабінет викладача</a>
                            </li>
                        }
                        @if (Context.Session.GetString("UserLogin") == null)
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-primary btn-sm" href="/Account/Login">Увійти</a>
                            </li>

                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm" href="/Account/Register">Реєстрація</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <span class="nav-link">👋 @Context.Session.GetString("UserLogin")</span>
                            </li>

                            <li class="nav-item">
                                <a class="btn btn-danger btn-sm" href="/Account/Logout">Вийти</a>
                            </li>
                        }
                    </ul>
                </div>

            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer mt-5">
        <div class="footer-container">

            <div class="footer-column">
                <h3>OnlineCourses</h3>
                <p>Платформа для онлайн-навчання, проходження курсів, тестів та відстеження прогресу.</p>

                <p class="footer-contact">
                    info@onlinecourses.ua<br />
                    +380675687433
                </p>

                <div class="social-icons">
                    <span>f</span>
                    <span>◎</span>
                    <span>in</span>
                    <span>▶</span>
                </div>
            </div>

            <div class="footer-column">
                <a href="/Home/Privacy">Про нас</a>
                <a href="/Courses">Каталог курсів</a>
                <a href="/Courses/Cabinet">Мої курси</a>
                <a href="/Account/Register">Реєстрація</a>
            </div>

            <div class="footer-column">
                <a href="#">Політика конфіденційності</a>
                <a href="#">Допомога</a>
                <a href="#">Публічна оферта</a>
                <a href="#">Звітність</a>
            </div>

            <div class="footer-column footer-apps">
                <div class="app-btn"> App Store</div>
                <div class="app-btn">▶ Google Play</div>

                <div class="payments">
                    <span>VISA</span>
                    <span>Mastercard</span>
                </div>
            </div>

        </div>

        <div class="footer-bottom">
            © 2026 OnlineCourses
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>