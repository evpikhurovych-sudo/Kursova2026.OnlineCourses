@model List<OnlineCourses.Web.Models.Course>

@{
    ViewData["Title"] = "Каталог курсів";
}

<div class="page-header">
    <h1>Каталог онлайн-курсів</h1>
    <p>Оберіть курс, перегляньте завдання та запишіться на навчання.</p>
</div>

<div class="row">
    @foreach (var course in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card course-card h-100">
                <img src="@course.ImageUrl" class="course-image" alt="course image" />

                <div class="card-body d-flex flex-column">
                    <h4>@course.Title</h4>
                    <p class="text-muted">@course.Description</p>
                    <p><b>Тривалість:</b> @course.Duration</p>

                    <a href="/Courses/Details/@course.Id" class="btn btn-primary mt-auto">
                        Детальніше
                    </a>
                </div>
            </div>
        </div>
    }
</div>